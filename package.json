{
  "name": "markdown-viewer",
  "version": "1.3.2",
  "description": "Advanced markdown viewer with translation, diagram rendering, and export capabilities",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "markdown",
    "viewer",
    "mermaid",
    "electron"
  ],
  "author": "Ofelia B Webb",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "mermaid": "^10.9.0",
    "highlight.js": "^11.11.0",
    "katex": "^0.16.9",
    "axios": "^1.8.0",
    "dompurify": "^3.2.0"
  },
  "build": {
    "appId": "com.dimpletz.markdown-viewer",
    "productName": "Markdown Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/assets/icon.png"
    }
  }
}
