# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF
*.py    text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.sh    text eol=lf
*.txt   text eol=lf

# Windows scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary — no line ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.docx  binary
