{
  "name": "markdown-viewer-electron",
  "version": "1.0.0",
  "description": "Electron frontend for Markdown Viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "markdown",
    "viewer",
    "electron"
  ],
  "author": "Ofelia B Webb",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "marked": "^11.0.0",
    "mermaid": "^10.6.0",
    "highlight.js": "^11.9.0",
    "katex": "^0.16.9",
    "axios": "^1.6.0",
    "dompurify": "^3.0.0"
  },
  "build": {
    "appId": "com.dimpletz.markdown-viewer",
    "productName": "Markdown Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
